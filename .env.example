# ============================================
# DeployPilot Environment Variables
# ============================================
# Copy this file to .env and fill in the values.
# NEVER commit the actual .env file to Git.

# --- Frontend (Netlify) ---
VITE_API_BASE_URL=https://your-backend.onrender.com/api
VITE_APP_NAME=DeployPilot

# --- Backend (Render) ---
SPRING_PROFILES_ACTIVE=prod
DATABASE_URL=jdbc:postgresql://your-db-host:5432/deploypilot?sslmode=require
DATABASE_USERNAME=your-db-username
DATABASE_PASSWORD=your-db-password
JWT_SECRET=generate-a-long-random-secret-at-least-64-characters
GEMINI_API_KEY=your-gemini-api-key-from-google-ai-studio
FRONTEND_URL=https://your-frontend.netlify.app

# --- Controlled Deployment Automation (Stage 4) ---
# REQUIRED in production. Encrypts each user's provider tokens and stored
# deployment secrets at rest (AES-256-GCM). Production refuses to start without
# a unique, strong value. Generate one with: openssl rand -base64 32
DEPLOYPILOT_ENCRYPTION_KEY=generate-with-openssl-rand-base64-32
# Optional. Master switch for performing real external changes (Deploy-for-me).
# DEPLOYPILOT_AUTOMATION_ENABLED=true
# Optional. How long a confirmation stays valid before it must be re-issued.
# DEPLOYPILOT_CONFIRMATION_TTL_SECONDS=600
# Optional. Override provider API base URLs (used by tests/mocks; leave unset in prod).
# GITHUB_API_BASE_URL=https://api.github.com
# NETLIFY_API_BASE_URL=https://api.netlify.com/api/v1
# RENDER_API_BASE_URL=https://api.render.com/v1

# Provider tokens are NOT configured here — each user connects their own GitHub,
# Netlify and Render accounts in the app (Connections page). Their tokens are
# encrypted per-user and never placed in environment variables.

# --- Optional: Firebase Cloud Messaging ---
# FIREBASE_ENABLED=true
# FIREBASE_PROJECT_ID=your-project-id
# FIREBASE_PRIVATE_KEY=-----BEGIN PRIVATE KEY-----...-----END PRIVATE KEY-----\n
# FIREBASE_CLIENT_EMAIL=firebase-adminsdk@your-project.iam.gserviceaccount.com
